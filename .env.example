# ── Database ─────────────────────────────────────────────────
# PostgreSQL required (schema.prisma uses postgresql provider)
# Get a free DB at: https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@host:5432/immigai?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────
# Your deployed URL (no trailing slash)
NEXTAUTH_URL="https://your-app.vercel.app"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-any-32-char-random-string"

# ── Anthropic AI ─────────────────────────────────────────────
# Required for AI features (chat, RFE drafting, document review)
ANTHROPIC_API_KEY="sk-ant-..."

# ── File Storage (Vercel Blob) ────────────────────────────────
# Required for persistent document uploads on Vercel
# 1. Run: npx vercel blob add
# 2. Paste the token here
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── Cron Security ────────────────────────────────────────────
# Protects /api/regulatory/fetch from unauthorized calls
# Generate with: openssl rand -hex 32
CRON_SECRET="generate-a-random-secret-here"

# ── App URL ──────────────────────────────────────────────────
# Used for Server Actions allowedOrigins + image domains
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# ── Demo Mode ────────────────────────────────────────────────
# Set to "true" ONLY for demo/staging deployments
# Pre-fills login form with demo credentials
NEXT_PUBLIC_DEMO_MODE="false"

# ── Email (optional) ─────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG...
